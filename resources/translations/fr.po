#: src/dos/programs/mouse.cpp:167
#, c-format, no-wrap
msgctxt "PROGRAM_MOUSE_HELP_LONG"
msgid ""
"Load the built-in mouse driver.\n"
"\n"
"Usage:\n"
"  [color=light-green]mouse[reset] [on] [/e] [/q]\n"
"\n"
"Parameters:\n"
"  on    load driver (default action)\n"
"  /e    load driver into low (conventional) memory\n"
"  /q    quiet mode (skip confirmation messages)\n"
"\n"
"Notes:\n"
"  The built-in driver bypasses the PS/2 and serial (COM) ports and communicates\n"
"  with the mouse directly. This results in lower input lag, smoother movement,\n"
"  and increased mouse responsiveness.\n"
msgstr ""
"Charge le pilote souris intégré.\n"
"\n"
"Usage :\n"
" [color=light-green]mouse[reset] [on] [/e] [/q]\n"
"\n"
"Paramètres :\n"
" on    charge le pilote (action par défaut)\n"
" /e    charge le pilote en mémoire basse (conventionnelle)\n"
" /q    mode silencieux (ignore les messages de confirmation)\n"
"\n"
"Notes :\n"
" Le pilote intégré contourne les ports PS/2 et série (COM) et communique\n"
" directement avec la souris. Cela réduit la latence d'entrée, rend le\n"
" mouvement plus fluide et améliore la réactivité.\n"

