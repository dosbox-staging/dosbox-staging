#: src/config/setup.cpp:278
#, c-format, no-wrap
msgctxt "CONFIGITEM_OUTPUT_OPENGL_DEFAULT"
msgid ""
"Rendering backend to use for graphics output ('opengl' by default). Only the\n"
"'opengl' backend has shader support and is thus the preferred option. The\n"
"'texture' backend is only provided as a last resort fallback if OpenGL is not\n"
"available or the OpenGL driver is not Core Profile 3.3 compliant. Possible\n"
"values:\n"
msgstr ""
"Zu verwendendes Rendering-Backend für die Grafikausgabe (standardmäßig\n"
"'opengl'). Nur das 'opengl'-Backend unterstützt Shader und ist daher die\n"
"bevorzugte Option. Das 'texture'-Backend dient lediglich als Ausweichlösung\n"
"für den Fall, dass OpenGL nicht verfügbar ist oder der OpenGL-Treiber nicht\n"
"mit Core Profile 3.3 kompatibel ist. Mögliche Werte:\n"

#: src/config/setup.cpp:278
#, c-format, no-wrap
msgctxt "CONFIGITEM_OUTPUT_TEXTURE_DEFAULT"
msgid "Rendering backend to use for graphics output ('texture' by default)."
msgstr ""
"Zu verwendendes Rendering-Backend für die Grafikausgabe\n"
"(standardmäßig 'texture')."

#: src/config/setup.cpp:278
#, c-format, no-wrap
msgctxt "CONFIGITEM_OUTPUT_OPENGL"
msgid "  opengl:     OpenGL backend with shader support (default)."
msgstr "  opengl:     OpenGL-Backend mit Shader-Unterstützung (Standard)."

#: src/config/setup.cpp:278
#, c-format, no-wrap
msgctxt "CONFIGITEM_OUTPUT_TEXTURE"
msgid "  texture:    SDL's texture backend with bilinear interpolation."
msgstr "  Textur:    Das SDL Textur-Backend mit bilinearer Interpolation."

#: src/config/setup.cpp:278
#, c-format, no-wrap
msgctxt "CONFIGITEM_OUTPUT_TEXTURENB"
msgid ""
"  texturenb:  SDL's texture backend with nearest-neighbour interpolation\n"
"              (no bilinear)."
msgstr ""
"  texturenb: SDLs Textur-Backend mit Nearest-Neighbor-Interpolation\n"
"              (keine bilineare Interpolation)."

#: src/config/setup.cpp:262
#, c-format, no-wrap
msgctxt "CONFIG_TEXTURE_RENDERER"
msgid ""
"Render driver to use in 'texture' output mode ('auto' by default).\n"
"Use 'texture_renderer = auto' for an automatic choice."
msgstr ""
"Zu verwendender Renderer-Treiber, wenn du einen Textur-Ausgabemodus\n"
"verwendest (Standardmäßig 'auto').\n"
"Verwende 'texture_renderer = auto' für eine automatische Auswahl."

#: src/config/setup.cpp:262
#, c-format, no-wrap
msgctxt "CONFIG_DISPLAY"
msgid "Number of display to use; values depend on OS and user settings (0 by default)."
msgstr ""
"Nummer der zu verwendenden Anzeige; die Werte hängen vom Betriebssystem und den\n"
"Benutzereinstellungen ab (Standardwert '0')."

#: src/config/setup.cpp:262
#, c-format, no-wrap
msgctxt "CONFIG_FULLSCREEN"
msgid "Start in fullscreen mode ('off' by default)."
msgstr "Im Vollbildmodus starten (standardmäßig deaktiviert)."

#: src/config/setup.cpp:262
#, c-format, no-wrap
msgctxt "CONFIG_FULLRESOLUTION"
msgid ""
"The [color=light-green]'fullresolution'[reset] setting has been removed.\n"
"Please use [color=light-green]'fullscreen_mode'[reset] instead."
msgstr ""
"Die Einstellung [color=light-green]'fullresolution'[reset] wurde entfernt.\n"
"Bitte verwende stattdessen [color=light-green]'fullscreen_mode'[reset]."

#: src/config/setup.cpp:262
#, c-format, no-wrap
msgctxt "CONFIG_FULLSCREEN_MODE"
msgid "Set fullscreen mode ('standard' by default). Possible values:\n"
msgstr "Vollbildmodus aktivieren (Standardwert: 'standard'). Mögliche Werte:\n"

#: src/config/setup.cpp:278
#, c-format, no-wrap
msgctxt "CONFIGITEM_FULLSCREEN_MODE_STANDARD"
msgid ""
"  standard:           Use the standard fullscreen mode of your operating system\n"
"                      (default).\n"
msgstr ""
"  standard:           Verwendet den Standard-Vollbildmodus deines Betriebssystems\n"
"                      (Standard).\n"

#: src/config/setup.cpp:278
#, c-format, no-wrap
msgctxt "CONFIGITEM_FULLSCREEN_MODE_FORCED-BORDERLESS"
msgid ""
"  forced-borderless:  Force borderless fullscreen operation if your graphics\n"
"                      card driver decides to disable fullscreen optimisation\n"
"                      on Windows, resulting in exclusive fullscreen. Forcing\n"
"                      borderless mode might result in decreased performance\n"
"                      and slightly worse frame pacing (e.g., scrolling in 2D\n"
"                      games not appearing perfectly smooth)."
msgstr ""
"  forced-borderless: Erzwingt den randlosen Vollbildmodus, falls der Treiber\n"
"                      deiner Grafikkarte unter Windows die Vollbildoptimierung\n"
"                      deaktiviert, was zu einem exklusiven Vollbildmodus führt.\n"
"                      Das Erzwingen des randlosen Modus kann zu einer \n"
"                      verminderten Leistung und einem leicht schlechteren\n"
"                      Frame-Pacing führen (z. B. erscheint das Scrollen in\n"
"                      2D-Spielen nicht vollkommen flüssig)."

#: src/config/setup.cpp:262
#, c-format, no-wrap
msgctxt "CONFIG_WINDOWRESOLUTION"
msgid ""
"The [color=light-green]'windowresolution'[reset] setting is deprecated but still accepted;\n"
"please use [color=light-green]'window_size'[reset] instead."
msgstr ""
"Die Einstellung [color=light-green]'windowresolution'[reset] ist veraltet,\n"
"wird aber weiterhin akzeptiert; verwende stattdessen [color=light-green]'window_size'[reset]."

#: src/config/setup.cpp:262
#, c-format, no-wrap
msgctxt "CONFIG_WINDOW_SIZE"
msgid ""
"Set initial window size for windowed mode ('default' by default). You can still\n"
"resize the window after startup. Possible values:\n"
"\n"
"  default:   Select the best option based on your environment and other\n"
"             factors (such as whether aspect ratio correction is enabled).\n"
"\n"
"  small, medium, large (s, m, l):\n"
"             Size the window relative to the desktop.\n"
"\n"
"  WxH:       Specify window size in WxH format in logical units (e.g.,\n"
"             1024x768). The values be multiplied by the OS-level DPI scaling to\n"
"             get the window size in pixels.\n"
"\n"
"Note: If you want to use pixel coordinates instead and ignore DPI scaling, set\n"
"      the SDL_WINDOWS_DPI_SCALING environment variable to 0."
msgstr ""
"Legt die anfängliche Fenstergröße für den Fenstermodus fest\n"
"(standardmäßig 'default'). Du kannst\n"
"die Fenstergröße nach dem Start weiterhin anpassen. Mögliche Werte:\n"
"\n"
"  default:   Wählt die beste Option basierend auf deiner Umgebung und anderen\n"
"             Faktoren (z. B. ob die Seitenverhältniskorrektur aktiviert ist).\n"
"\n"
"  small, medium, large (s, m, l):\n"
"             Passt die Fenstergröße relativ zum Desktop an.\n"
"\n"
"  BxH:       Gib die Fenstergröße im Format BxH in logischen Einheiten an\n"
"             (z. B. 1024x768). Die Werte werden mit der DPI-Skalierung auf\n"
"             Betriebssystemebene multipliziert, um die Fenstergröße in Pixeln\n"
"             zu erhalten.\n"
"\n"
"Hinweis: Wenn du stattdessen Pixelkoordinaten verwenden und die DPI-Skalierung\n"
"             ignorieren möchtest, setze die Umgebungsvariable\n"
"             SDL_WINDOWS_DPI_SCALING auf 0."

#: src/config/setup.cpp:262
#, c-format, no-wrap
msgctxt "CONFIG_WINDOW_POSITION"
msgid ""
"Set initial window position for windowed mode ('auto' by default).\n"
"Possible values:\n"
"\n"
"  auto:      Let the window manager decide the position (default).\n"
"\n"
"  X,Y:       Set window position in X,Y format in logical units (e.g., 250,100).\n"
"             0,0 is the top-left corner of the screen. The values will be\n"
"             multiplied by the OS-level DPI scaling to get the window position\n"
"             in pixels.\n"
"\n"
"Note: If you want to use pixel coordinates instead and ignore DPI scaling, set\n"
"      the SDL_WINDOWS_DPI_SCALING environment variable to 0."
msgstr ""
"Legt die anfängliche Fensterposition für den Fenstermodus fest\n"
"(Standardwert: 'auto').\n"
"Mögliche Werte:\n"
"\n"
"  auto:      Der Fenstermanager bestimmt die Position (Standard).\n"
"\n"
"  X,Y:       Legt die Fensterposition im X,Y-Format in logischen Einheiten\n"
"             fest (z. B. 250,100). 0,0 ist die obere linke Ecke des Bild-\n"
"             schirms. Die Werte werden mit der DPI-Skalierung auf Betriebs-\n"
"             systemebene multipliziert, um die Fensterposition in Pixeln\n"
"             zu erhalten."

#: src/config/setup.cpp:262
#, c-format, no-wrap
msgctxt "CONFIG_WINDOW_DECORATIONS"
msgid "Enable window decorations in windowed mode ('on' by default)."
msgstr ""
"Legt fest, ob der Rahmen im Fenster-Modus angezeigt werden soll (standardmäßig\n"
"aktiviert)."

#: src/config/setup.cpp:262
#, c-format, no-wrap
msgctxt "CONFIG_WINDOW_TITLEBAR"
msgid ""
"Space separated list of information to be displayed in the window's titlebar\n"
"('program=name dosbox=auto cycles=on mouse=full' by default). If a parameter\n"
"is not specified, its default value is used. Possible information to display:\n"
"\n"
"  animation=<value>:  If set to 'on' (default), animate the audio/video\n"
"                      recording mark. Set to 'off' to disable animation; this\n"
"                      is useful if your screen font produces weird results.\n"
"\n"
"  program=<value>:    Display the name of the running program.\n"
"                      <value> can be one of:\n"
"                        none/off:  Do not display program name.\n"
"                        name:      Program name, with file extension (default).\n"
"                        path:      Name, extension, and full absolute path.\n"
"                        segment:   Display program memory segment name.\n"
"                        'Title':   Custom name. Alternatively, you can use\n"
"                                   \"Title\", (Title), <Title> or [Title] form.\n"
"\n"
"                      Note: With some software (like Windows 3.1 in enhanced\n"
"                      mode) it is impossible to recognize the full program\n"
"                      name or path; in such cases 'segment' is used instead.\n"
"\n"
"  dosbox=<value>:     Display 'DOSBox Staging' in the title bar.\n"
"                      <value> can be one of:\n"
"                        always:   Always display 'DOSBox Staging'.\n"
"                        auto:     Only display it if no program is running or\n"
"                                  'program=none' is set (default).\n"
"\n"
"  version=<value>:    Display DOSBox version information.\n"
"                      <value> can be one of:\n"
"                         none/off:  Do not display DOSBox version (default).\n"
"                         simple:    Simple version information.\n"
"                         detailed:  Include Git hash, if available.\n"
"\n"
"  cycles=<value>:     If set to 'on' (default), show CPU cycles setting.\n"
"                      Set to 'off' to disable cycles setting display.\n"
"\n"
"  mouse=<value>:      Mouse capturing hint verbosity level:\n"
"                        none/off:  Do not display any mouse hints.\n"
"                        short:     Only display if mouse is captured.\n"
"                        full:      Display verbose information on how to\n"
"                                   capture or release the cursor (default)."
msgstr ""
"Durch Leerzeichen getrennte Liste von Informationen, die in der Titelleiste des\n"
"Fensters angezeigt werden sollen ('program=name dosbox=auto cycles=on\n"
"mouse=full' als Standard).\n"
"Wenn ein Parameter nicht angegeben ist, wird sein Standardwert verwendet.\n"
"Mögliche Informationen, die angezeigt werden können, sind:\n"
"\n"
"  animation=<value>:  Wenn diese Option auf 'on' gesetzt ist (Standard), wird\n"
"                      die Audio-/Video Aufnahmemarkierung animiert. Auf 'off'\n"
"                      gesetzt, wird die Animation deaktiviert; dies ist\n"
"                      nützlich, wenn Ihre Schriftart Probleme macht.\n"
"\n"
"  program=<value>:    Zeigt den Namen des laufenden Programms an.\n"
"                      <Wert> kann einer der folgenden Werte sein:\n"
"                          none/off:  Den Programmnamen nicht anzeigen.\n"
"                          name:      Programmname, Erweiterung (Standard).\n"
"                          path:      Name, Erweiterung und vollständiger Pfad.\n"
"                          segment:   Programmspeichersegment anzeigen.\n"
"                          'Titel':   Benutzerdefinierter Name. Alternativ\n"
"                                     kannst du folgende Formate verwenden:\n"
"                                     'Titel', (Titel), <Title> oder [Titel].\n"
"\n"
"                      Hinweis: Bei manchen Programmen (wie Windows 3.1x im\n"
"                      erweiterten Modus) ist es unmöglich, den vollständigen\n"
"                      Programmnamen oder Pfad zu erkennen; in solchen Fällen\n"
"                      wird stattdessen 'segment' verwendet.\n"
"\n"
"  dosbox=<value>:     Anzeige von 'DOSBox Staging' in der Titelleiste.\n"
"                      <Wert> kann einer der folgenden Werte sein:\n"
"                        always:   Zeigt immer 'DOSBox Staging' an.\n"
"                        auto:     Wird nur angezeigt, wenn kein Spiel läuft\n"
"                                  oder 'program=none' gesetzt ist\n"
"                                  (Voreinstellung).\n"
"\n"
"  version=<value>:    Anzeige der DOSBox-Versionsinformationen.\n"
"                      <Wert> kann einer der folgenden Werte sein:\n"
"                         none/off:  DOSBox-Version nicht anzeigen (Standard).\n"
"                         simple:    Einfache Versionsinformationen.\n"
"                         detailed:  Git-Hash einbeziehen, falls verfügbar.\n"
"\n"
"  cycles=<value>:     Bei der Einstellung 'on' (Standard) wird die emulierte\n"
"                      CPU Geschwindigkeit angezeigt. Setze die Einstellung auf\n"
"                      'off', um die Anzeige zu deaktivieren.\n"
"\n"
"  mouse=<value>:      Stufe der Mausumschaltungs-Hinweise:\n"
"                        none/off:  Keine Maus-Hinweise anzeigen.\n"
"                        short:     Nur anzeigen, wenn die Maus umgeschaltet\n"
"                                   wird.\n"
"                        full:      Zeigt ausführliche Informationen zum\n"
"                                   Umschalten der Maus an (Standard)."

