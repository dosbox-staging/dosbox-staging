msgctxt "PROGRAM_SHOWPIC_HELP"
msgid "Display an image file.\n"
msgstr "Eine Bilddatei anzeigen.\n"

#: src/dos/programs/showpic.cpp:257
#, c-format, no-wrap
msgctxt "PROGRAM_SHOWPIC_HELP_LONG"
msgid ""
"Usage:\n"
"  [color=light-green]showpic[reset] [color=light-cyan]FILE[reset]\n"
"\n"
"Parameters:\n"
"  [color=light-cyan]FILE[reset]  name of a BMP, GIF, IFF/LBM, PCX, or PNG image file to display\n"
"\n"
"Notes:\n"
"  - An S3 SVGA display adapter is required.\n"
"  - Only paletted images are supported.\n"
"  - Press any key to exit the program.\n"
"  - You can use the program to view raw PNG screenshots created by DOSBox\n"
"    Staging (except for screenshots taken with composite emulation enabled).\n"
"\n"
"Examples:\n"
"  [color=light-green]showpic[reset] [color=light-cyan]image1.png[reset]\n"
"  [color=light-green]showpic[reset] [color=light-cyan]d:\\pics\\gods.iff[reset]\n"
msgstr ""
"Verwendung:\n"
"  [color=light-green]showpic[reset] [color=light-cyan]DATEI[reset]\n"
"\n"
"Parameter:\n"
"  [color=light-cyan]DATEI[reset]  Name einer anzuzeigenden BMP-, GIF-,\n"
"  IFF/LBM-, PCX- oder PNG-Bilddatei\n"
"\n"
"Hinweise:\n"
"  - Ein S3-SVGA-Grafikkarte ist erforderlich.\n"
"  - Es werden nur Bilder mit einer Farbpalette unterstützt.\n"
"  - Drücke eine beliebige Taste, um das Programm zu beenden.\n"
"  - Du kannst das Programm verwenden, um von DOSBox\n"
"    Staging erstellte Roh-PNG-Screenshots anzuzeigen\n"
"    (mit Ausnahme von Screenshots, die bei aktivierter Composite-Emulation\n"
"    aufgenommen wurden).\n"
"\n"
"Beispiele:\n"
"  [color=light-green]showpic[reset] [color=light-cyan]bild1.png[reset]\n"
"  [color=light-green]showpic[reset] [color=light-cyan]d:\\bilder\\gods.iff[reset]\n"

