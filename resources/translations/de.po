#: src/dos/programs/mouse.cpp:167
#, c-format, no-wrap
msgctxt "PROGRAM_MOUSE_HELP_LONG"
msgid ""
"Load the built-in mouse driver.\n"
"\n"
"Usage:\n"
"  [color=light-green]mouse[reset] [on] [/e] [/q]\n"
"\n"
"Parameters:\n"
"  on    load driver (default action)\n"
"  /e    load driver into low (conventional) memory\n"
"  /q    quiet mode (skip confirmation messages)\n"
"\n"
"Notes:\n"
"  The built-in driver bypasses the PS/2 and serial (COM) ports and communicates\n"
"  with the mouse directly. This results in lower input lag, smoother movement,\n"
"  and increased mouse responsiveness.\n"
msgstr ""
"Lade den integrierten Maustreiber.\n"
"\n"
"Verwendung:\n"
"  [color=light-green]mouse[reset] [on] [/e] [/q]\n"
"\n"
"Parameter:\n"
"  on    Treiber laden (Standardaktion)\n"
"  /e    Treiber in den Low-Speicher (konventionellen Speicher) laden\n"
"  /q    Stiller Modus (Bestätigungsmeldungen überspringen)\n"
"\n"
"Hinweise:\n"
"  Der integrierte Treiber umgeht die PS/2- und seriellen (COM)-Anschlüsse\n"
"  und kommuniziert direkt mit der Maus. Dies führt zu einer geringeren\n"
"  Eingabeverzögerung, flüssigeren Bewegungen und einer erhöhten\n"
"  Reaktionsfähigkeit der Maus.\n"

