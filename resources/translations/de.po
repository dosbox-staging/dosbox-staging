#: src/shell/shell.cpp:614
#, c-format, no-wrap
msgctxt "SHELL_CMD_DATE_SETHLP"
msgid "Run [color=yellow]date %s[reset] to change the current date.\n"
msgstr "Führe [color=yellow]date %s[reset] aus, um das aktuelle Datum zu ändern.\n"

#: src/shell/shell.cpp:616
#, c-format, no-wrap
msgctxt "SHELL_CMD_DATE_HELP_LONG"
msgid ""
"Usage:\n"
"  [color=light-green]date[reset] [/t]\n"
"  [color=light-green]date[reset] /h\n"
"  [color=light-green]date[reset] [color=light-cyan]DATE[reset]\n"
"\n"
"Parameters:\n"
"  [color=light-cyan]DATE[reset]  new date to set to, in the format of [color=light-cyan]%s[reset]\n"
"\n"
"Notes:\n"
"  Running [color=light-green]date[reset] without an argument shows the current date, or a simple date\n"
"  with the /t option. You can force a date synchronization with the host system\n"
"  with the /h option, or manually specify a new date to set to.\n"
"\n"
"Examples:\n"
"  [color=light-green]date[reset]\n"
"  [color=light-green]date[reset] /h\n"
"  [color=light-green]date[reset] [color=light-cyan]%s[reset]\n"
msgstr ""
"Verwendung:\n"
"  [color=light-green]date[reset] [/t]\n"
"  [color=light-green]date[reset] /h\n"
"  [color=light-green]date[reset] [color=light-cyan]DATUM[reset]\n"
"\n"
"Parameter:\n"
"  [color=light-cyan]DATUM[reset] ist das neu zu setzende Datum, im Format [color=light-cyan]%s[reset].\n"
"\n"
"Anmerkungen:\n"
"  Wenn du [color=light-green]date[reset] ohne Parameter ausführst, wird das aktuelle Datum angezeigt,\n"
"  oder nur ein Datum mit der Option /t. Mit der Option /h kannst du eine\n"
"  Datumssynchronisation mit dem Host-System erzwingen oder manuell ein neues\n"
"  Datum angeben, das gesetzt werden soll.\n"
"\n"
"Beispiele:\n"
"  [color=light-green]date[reset]\n"
"  [color=light-green]date[reset] /h\n"
"  [color=light-green]date[reset] [color=light-cyan]%s[reset]\n"

